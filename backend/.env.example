# Server Configuration
PORT=3001
HOST=0.0.0.0
FRONTEND_URL=http://localhost:3000

# Database
DB_PATH=/var/lib/trakend-os/trakend.db

# JWT
JWT_SECRET=your-secret-key-change-in-production

# Docker
DOCKER_SOCKET=/var/run/docker.sock

# Logging
LOG_LEVEL=info
LOG_FILE=/var/log/trakend-os/app.log

# Maya AI
MAYA_ENABLED=true
OLLAMA_URL=http://localhost:11434
MAYA_MODEL=neural-chat

# Git Updates
GIT_REPO_URL=https://github.com/trakend/trakend-os.git
GIT_BRANCH=main
