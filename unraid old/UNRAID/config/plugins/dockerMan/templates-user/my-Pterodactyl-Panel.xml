  <Config Name="UrlOfPanel" Target="APP_URL" Default="https://example.com" Mode="" Description="Set your Url of the panel, used in mail." Type="Variable" Display="always" Required="true" Mask="false">https://admin.allaycraftsmp.com</Config>
