  <Requires>Pterodactyl-Deamons.&#xD;
br  Redis server. (above V1.7.0)</Requires>
  <Config Name="WebHttp" Target="80" Default="80" Mode="tcp" Description="Port Http for the web serveur" Type="Port" Display="always" Required="true" Mask="false">8081</Config>
  <Config Name="WebHttps" Target="443" Default="443" Mode="tcp" Description="Port Https for the web serveur" Type="Port" Display="always" Required="true" Mask="false">8444</Config>
  <Config Name="PteroVar" Target="/app/var" Default="/mnt/user/appdata/pteropanel/var" Mode="rw" Description="" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/pteropanel/var</Config>
  <Config Name="PteroNginx" Target="/app/nginx/http.d/" Default="" Mode="rw" Description="" Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/pteropanel/nginx</Config>
  <Config Name="PteroLogs" Target="/app/storage/logs" Default="/mnt/user/appdata/pteropanel/logs" Mode="rw" Description="All the logs of pterodactyl panel." Type="Path" Display="always" Required="true" Mask="false">/mnt/user/appdata/pteropanel/logs</Config>
  <Config Name="DatabaseHost" Target="DB_HOST" Default="" Mode="" Description="Ip of your database" Type="Variable" Display="always" Required="true" Mask="false">192.168.1.228</Config>
  <Config Name="DatabasePort" Target="DB_PORT" Default="3306" Mode="" Description="The port of your database" Type="Variable" Display="always" Required="true" Mask="false">3307</Config>
  <Config Name="DatabaseName" Target="DB_DATABASE" Default="pterodb" Mode="" Description="The name of your database." Type="Variable" Display="always" Required="true" Mask="false">pterodb</Config>
  <Config Name="DatabaseUser" Target="DB_USERNAME" Default="PteroUser" Mode="" Description="The name of the database user" Type="Variable" Display="always" Required="true" Mask="false">PteroUser</Config>
