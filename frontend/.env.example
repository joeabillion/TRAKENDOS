# Trakend OS Frontend Environment Variables

# Backend API URL
VITE_API_URL=http://localhost:3001/api

# WebSocket URL (optional - defaults to protocol-relative /ws)
VITE_WS_URL=ws://localhost:3001/ws

# Feature flags
VITE_ENABLE_MAYA=true
VITE_ENABLE_DOCKER=true
VITE_ENABLE_DATABASE=true
VITE_ENABLE_TERMINAL=true
VITE_ENABLE_LOGS=true

# Application settings
VITE_APP_NAME=Trakend OS
VITE_APP_VERSION=1.0.0

# Debug mode
VITE_DEBUG=false
